{
  "name": "claude-notify",
  "version": "1.0.0",
  "description": "A command-line notification tool for Claude Code hooks using Pushover",
  "main": "index.ts",
  "scripts": {
    "start": "bun run index.ts",
    "build": "bun build index.ts --outdir ./dist --target bun",
    "dev": "bun run --watch index.ts",
    "test": "echo '{\"session_id\": \"sample-session-123\", \"transcript_path\": \"~/.claude/projects/-Users-max-Projects-claude-notify/30dff0e2-6143-4292-839a-d035129ab4f7.jsonl\", \"hook_event_name\": \"Stop\", \"stop_hook_active\": false}' | bun run claude-notify.ts",
    "debug": "echo '{\"session_id\": \"debug-session-123\", \"transcript_path\": \"~/.claude/projects/claude-notify/debug.jsonl\", \"hook_event_name\": \"Stop\", \"stop_hook_active\": false}' | ./debug-wrapper.sh"
  },
  "bin": {
    "claude-notify": "./index.ts"
  },
  "dependencies": {
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "bun-types": "^1.3.10",
    "typescript": "^5.0.0",
    "xo": "^1.2.3"
  },
  "keywords": [
    "claude",
    "notifications",
    "pushover",
    "cli"
  ],
  "author": "",
  "license": "MIT",
  "xo": {
    "space": true,
    "semicolon": false,
    "rules": {
      "@stylistic/quotes": ["error", "double"],
      "@typescript-eslint/naming-convention": "off",
      "unicorn/filename-case": "off",
      "unicorn/no-process-exit": "off",
      "import-x/extensions": "off",
      "n/prefer-global/process": "error",
      "n/prefer-global/buffer": "error",
      "@typescript-eslint/no-restricted-types": "error"
    }
  }
}
